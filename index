function buildCards(sec,data){
  const grid=document.getElementById('grid'+sec[0].toUpperCase()+sec.slice(1));
  data.forEach(s=>{
    const c=document.createElement('div');c.className='card';c.id='card-'+s.id;
    c.innerHTML=`<div class="pulse"></div><span class="card-icon">${s.icon}</span><div class="card-name">${s.name}</div><div class="card-sub">${s.sub}</div><input type="range" class="card-vol" min="0" max="1" step="0.01" value="0.7" data-id="${s.id}">`;
    c.addEventListener('click',e=>{if(e.target.classList.contains('card-vol'))return;toggleSound(s.id,s.gen);});
    c.querySelector('.card-vol').addEventListener('input',e=>{e.stopPropagation();if(nodes[s.id])nodes[s.id].gain.setTargetAtTime(parseFloat(e.target.value),ctx.currentTime,.05);});
    grid.appendChild(c);
  });
}
Object.entries(sounds).forEach(([k,v])=>buildCards(k,v));

function toggleSound(id,gen){
  ensureCtx();
  if(nodes[id]){
    nodes[id].gain.linearRampToValueAtTime(0,ctx.currentTime+1);
    setTimeout(()=>{if(nodes[id]){nodes[id].disconnect();delete nodes[id];}},1100);
    document.getElementById('card-'+id)?.classList.remove('playing');
  }else{
    const g=gen();g.connect(masterGain);nodes[id]=g;
    document.getElementById('card-'+id)?.classList.add('playing');
  }
  updateCount();
}

function updateCount(){
  const n=Object.keys(nodes).length;
