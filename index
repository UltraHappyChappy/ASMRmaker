<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>ASMR Pad</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@300;400;500&family=Cormorant+Garamond:ital,wght@0,300;1,300&display=swap');
:root{--bg:#0a0c10;--surface:#111318;--surface2:#181c24;--border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.14);--text:#e8e4dc;--muted:rgba(232,228,220,0.38);--accent:#7eb8c4;--accent2:#c4a87e;--glow:rgba(126,184,196,0.15);--danger:#c47e7e;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'Zen Kaku Gothic New',sans-serif;font-weight:300;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:radial-gradient(ellipse 80% 50% at 20% 30%,rgba(126,184,196,0.04) 0%,transparent 60%),radial-gradient(ellipse 60% 40% at 80% 70%,rgba(196,168,126,0.03) 0%,transparent 50%);pointer-events:none;z-index:0;}
.wrap{position:relative;z-index:1;max-width:700px;margin:0 auto;padding:2rem 1.1rem 5rem;}
/* HEADER */
header{text-align:center;margin-bottom:2rem;}
.logo{font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:300;font-size:clamp(2rem,8vw,3rem);letter-spacing:.15em;color:var(--accent);margin-bottom:.25rem;}
.tagline{font-size:.68rem;letter-spacing:.35em;text-transform:uppercase;color:var(--muted);}
/* TABS */
.tabs{display:flex;gap:.5rem;margin-bottom:1.5rem;border-bottom:1px solid var(--border);padding-bottom:0;}
.tab{padding:.55rem 1rem;font-size:.75rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:color .2s,border-color .2s;-webkit-tap-highlight-color:transparent;}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);}
.tab-pane{display:none;}.tab-pane.active{display:block;}
/* MASTER */
.master-bar{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:1rem 1.25rem;margin-bottom:1.25rem;display:flex;align-items:center;gap:.9rem;flex-wrap:wrap;}
.master-label{font-size:.72rem;letter-spacing:.18em;color:var(--muted);white-space:nowrap;text-transform:uppercase;}
.vol-track{flex:1;min-width:80px;-webkit-appearance:none;appearance:none;height:3px;border-radius:2px;background:var(--border);outline:none;cursor:pointer;}
.vol-track::-webkit-slider-thumb{-webkit-appearance:none;width:17px;height:17px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--glow);cursor:pointer;transition:transform .15s;}
.vol-track::-webkit-slider-thumb:active{transform:scale(1.25);}
.vol-track::-moz-range-thumb{width:17px;height:17px;border-radius:50%;background:var(--accent);border:none;cursor:pointer;}
.badge{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:20px;border:1px solid var(--border);font-size:.62rem;letter-spacing:.12em;color:var(--muted);text-transform:uppercase;white-space:nowrap;}
.badge-dot{width:5px;height:5px;border-radius:50%;background:var(--muted);transition:background .3s;}
/* CANVAS */
#waveCanvas{width:100%;height:52px;display:block;margin-bottom:1.25rem;border-radius:8px;opacity:.65;}
/* SECTION */
.sec-title{font-size:.65rem;letter-spacing:.3em;text-transform:uppercase;color:var(--muted);margin-bottom:.65rem;padding-left:.2rem;}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(148px,1fr));gap:.65rem;margin-bottom:1.75rem;}
/* CARD */
.card{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:1rem .9rem .8rem;cursor:pointer;transition:border-color .25s,background .25s,transform .1s;user-select:none;-webkit-tap-highlight-color:transparent;position:relative;overflow:hidden;}
.card::before{content:'';position:absolute;inset:0;border-radius:13px;opacity:0;transition:opacity .3s;pointer-events:none;}
.card.playing{border-color:var(--accent);background:var(--surface2);}
.card.playing::before{opacity:1;background:radial-gradient(ellipse at 50% 0%,rgba(126,184,196,0.11),transparent 70%);}
.card:active{transform:scale(0.97);}
.card-icon{font-size:1.5rem;margin-bottom:.5rem;display:block;line-height:1;filter:saturate(.7) brightness(.9);transition:filter .3s;}
.card.playing .card-icon{filter:saturate(1) brightness(1.1);}
.card-name{font-size:.8rem;font-weight:400;letter-spacing:.04em;margin-bottom:.25rem;}
.card-sub{font-size:.65rem;color:var(--muted);letter-spacing:.03em;margin-bottom:.65rem;}
.card-vol{width:100%;-webkit-appearance:none;appearance:none;height:2px;border-radius:1px;background:var(--border);outline:none;cursor:pointer;}
.card-vol::-webkit-slider-thumb{-webkit-appearance:none;width:13px;height:13px;border-radius:50%;background:rgba(126,184,196,.75);cursor:pointer;transition:transform .15s;}
.card-vol::-webkit-slider-thumb:active{transform:scale(1.3);}
.card-vol::-moz-range-thumb{width:13px;height:13px;border-radius:50%;background:rgba(126,184,196,.75);border:none;}
.pulse{position:absolute;top:.7rem;right:.7rem;width:6px;height:6px;border-radius:50%;background:var(--accent);opacity:0;transition:opacity .3s;}
.card.playing .pulse{opacity:1;animation:blink 2s ease-in-out infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:.25;}}
/* BUTTONS */
.btn-row{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1rem;}
.btn{padding:.6rem 1.1rem;border-radius:9px;border:1px solid var(--border);background:var(--surface);color:var(--text);font-family:'Zen Kaku Gothic New',sans-serif;font-weight:300;font-size:.78rem;letter-spacing:.07em;cursor:pointer;transition:border-color .2s,background .2s;-webkit-tap-highlight-color:transparent;}
.btn:hover{border-color:var(--border2);background:var(--surface2);}
.btn:active{transform:scale(.97);}
.btn.accent{border-color:rgba(126,184,196,.4);background:rgba(126,184,196,.07);color:var(--accent);}
.btn.accent:hover{background:rgba(126,184,196,.14);}
.btn.danger{border-color:rgba(196,126,126,.4);background:rgba(196,126,126,.07);color:var(--danger);}
/* ===== TIMELINE / SCHEDULER ===== */
.scheduler{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:1.25rem;margin-bottom:1.5rem;}
.sch-header{display:flex;align-items:center;gap:.75rem;margin-bottom:1.1rem;flex-wrap:wrap;}
.sch-title{font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);}
.sch-timer-display{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.5rem;color:var(--accent);letter-spacing:.1em;margin-left:auto;}
.sch-controls{display:flex;gap:.5rem;align-items:center;flex-wrap:wrap;margin-bottom:1rem;}
.sch-input-group{display:flex;align-items:center;gap:.4rem;}
.sch-input-group label{font-size:.68rem;color:var(--muted);letter-spacing:.1em;white-space:nowrap;}
.sch-input{background:var(--surface2);border:1px solid var(--border);border-radius:7px;color:var(--text);font-family:'Zen Kaku Gothic New',sans-serif;font-size:.8rem;padding:.35rem .6rem;width:70px;outline:none;text-align:center;}
.sch-input:focus{border-color:var(--accent);}
/* TIMELINE TRACK */
.timeline-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;margin-bottom:.75rem;}
.timeline{position:relative;height:auto;min-width:600px;}
.tl-ruler{height:24px;position:relative;border-bottom:1px solid var(--border);}
.tl-ruler-tick{position:absolute;bottom:0;width:1px;background:var(--border2);display:flex;flex-direction:column;align-items:center;}
.tl-ruler-label{font-size:.58rem;color:var(--muted);position:absolute;top:2px;transform:translateX(-50%);}
.tl-tracks{position:relative;}
.tl-row{display:flex;align-items:center;height:36px;border-bottom:1px solid var(--border);position:relative;}
.tl-row-label{width:88px;min-width:88px;font-size:.65rem;color:var(--muted);padding-right:.5rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex-shrink:0;}
.tl-lane{flex:1;position:relative;height:100%;cursor:crosshair;}
.tl-block{position:absolute;top:5px;height:26px;border-radius:5px;background:rgba(126,184,196,.25);border:1px solid rgba(126,184,196,.5);cursor:pointer;transition:background .15s;display:flex;align-items:center;justify-content:center;}
.tl-block:hover{background:rgba(126,184,196,.4);}
.tl-block.active-block{background:rgba(126,184,196,.45);border-color:var(--accent);}
.tl-block-x{font-size:.55rem;color:rgba(126,184,196,.9);padding:0 4px;pointer-events:none;white-space:nowrap;overflow:hidden;}
/* PLAYHEAD */
.tl-playhead{position:absolute;top:0;bottom:0;width:2px;background:var(--accent2);z-index:10;pointer-events:none;transition:left .1s linear;}
.tl-playhead::before{content:'';position:absolute;top:0;left:-4px;border:5px solid transparent;border-top:8px solid var(--accent2);}
/* SLEEP TIMER */
.sleep-section{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:1.1rem 1.25rem;margin-bottom:1.5rem;}
.sleep-row{display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;}
.sleep-label{font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);}
.sleep-chips{display:flex;gap:.4rem;flex-wrap:wrap;}
.chip{padding:.35rem .75rem;border-radius:20px;border:1px solid var(--border);font-size:.72rem;cursor:pointer;transition:all .2s;color:var(--muted);-webkit-tap-highlight-color:transparent;}
.chip.selected{border-color:var(--accent2);color:var(--accent2);background:rgba(196,168,126,.08);}
.sleep-countdown{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.1rem;color:var(--accent2);margin-left:auto;min-width:60px;text-align:right;}
/* FADE OUT BAR */
.fade-bar-wrap{height:4px;background:var(--border);border-radius:2px;margin-top:.75rem;overflow:hidden;display:none;}
.fade-bar{height:100%;background:linear-gradient(90deg,var(--accent2),rgba(196,168,126,.3));border-radius:2px;transition:width .5s linear;}
.footer-tip{margin-top:2rem;text-align:center;font-size:.65rem;letter-spacing:.15em;color:rgba(232,228,220,.18);text-transform:uppercase;}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="logo">ASMR Pad</div>
    <div class="tagline">ささやきの宇宙へ</div>
  </header>

  <!-- MASTER -->
  <div class="master-bar">
    <span class="master-label">Master</span>
    <input type="range" class="vol-track" id="masterVol" min="0" max="1" step="0.01" value="0.75">
    <div class="badge"><div class="badge-dot" id="activeDot"></div><span id="activeCount">0</span> active</div>
  </div>
  <canvas id="waveCanvas"></canvas>

  <!-- TABS -->
  <div class="tabs">
    <div class="tab active" data-tab="sounds">サウンド</div>
    <div class="tab" data-tab="scheduler">タイムライン</div>
    <div class="tab" data-tab="sleep">タイマー</div>
  </div>

  <!-- ===== TAB: SOUNDS ===== -->
  <div class="tab-pane active" id="tab-sounds">
    <div class="sec-title">自然の音</div>
    <div class="grid" id="gridNature"></div>
    <div class="sec-title">ささやき・耳かき</div>
    <div class="grid" id="gridWhisper"></div>
    <div class="sec-title">テクスチャ</div>
    <div class="grid" id="gridTexture"></div>
    <div class="sec-title">空間</div>
    <div class="grid" id="gridAmbient"></div>
    <div class="btn-row">
      <button class="btn danger" onclick="stopAll()">すべて停止</button>
      <button class="btn accent" onclick="savePreset()">プリセット保存</button>
      <button class="btn accent" onclick="loadPreset()">プリセット読込</button>
    </div>
  </div>

  <!-- ===== TAB: SCHEDULER ===== -->
  <div class="tab-pane" id="tab-scheduler">
    <div class="scheduler">
      <div class="sch-header">
        <span class="sch-title">タイムライン</span>
        <span class="sch-timer-display" id="schDisplay">00:00</span>
      </div>
      <div class="sch-controls">
        <div class="sch-input-group">
          <label>全体時間</label>
          <input type="number" class="sch-input" id="schDuration" value="30" min="1" max="180"> 分
        </div>
        <button class="btn accent" onclick="schPlay()" id="schPlayBtn">▶ 再生</button>
        <button class="btn" onclick="schStop()">■ 停止</button>
        <button class="btn" onclick="schClear()">クリア</button>
      </div>
      <p style="font-size:.68rem;color:var(--muted);margin-bottom:.75rem;letter-spacing:.04em;">レーンをクリックでブロック追加 / ブロックをクリックで削除</p>
      <div class="timeline-wrap">
        <div class="timeline" id="timeline">
          <div class="tl-ruler" id="tlRuler"></div>
          <div class="tl-tracks" id="tlTracks"></div>
          <div class="tl-playhead" id="tlPlayhead" style="left:88px;display:none;"></div>
        </div>
      </div>
    </div>
    <div class="btn-row">
      <button class="btn accent" onclick="schSave()">スケジュール保存</button>
      <button class="btn" onclick="schLoad()">読込</button>
    </div>
    <div class="footer-tip">ブロックをドラッグで移動 · 右端をドラッグでリサイズ</div>
  </div>

  <!-- ===== TAB: SLEEP TIMER ===== -->
  <div class="tab-pane" id="tab-sleep">
    <div class="sleep-section">
      <div class="sleep-row">
        <span class="sleep-label">スリープタイマー</span>
        <div class="sleep-chips" id="sleepChips">
          <div class="chip" data-min="15">15分</div>
          <div class="chip" data-min="30">30分</div>
          <div class="chip" data-min="60">60分</div>
          <div class="chip" data-min="90">90分</div>
          <div class="chip" data-min="120">120分</div>
        </div>
        <span class="sleep-countdown" id="sleepCountdown">—</span>
      </div>
      <div class="fade-bar-wrap" id="fadeBarWrap">
        <div class="fade-bar" id="fadeBar" style="width:100%"></div>
      </div>
    </div>
    <div class="sleep-section">
      <div class="sleep-row" style="margin-bottom:.75rem;">
        <span class="sleep-label">フェードアウト時間</span>
        <div class="sleep-chips" id="fadeChips">
          <div class="chip selected" data-sec="30">30秒</div>
          <div class="chip" data-sec="60">1分</div>
          <div class="chip" data-sec="120">2分</div>
          <div class="chip" data-sec="300">5分</div>
        </div>
      </div>
    </div>
    <div class="btn-row">
      <button class="btn danger" onclick="cancelSleep()">タイマーキャンセル</button>
    </div>
    <div class="footer-tip">タイマー終了時、フェードアウト後に自動停止します</div>
  </div>

  <div class="footer-tip">各カードをタップして再生 · スライダーで音量調整</div>
</div>

<script>
const AC = window.AudioContext || window.webkitAudioContext;

// ====== SAMPLE AUDIO (brushing) ======
const BRUSHING_B64 = "";
let brushingBuffer = null;

let ctx=null, masterGain=null, analyser=null;
const nodes={};

function ensureCtx(){
  if(!ctx){
    ctx=new AC();
    masterGain=ctx.createGain(); masterGain.gain.value=.75;
    analyser=ctx.createAnalyser(); analyser.fftSize=512;
    masterGain.connect(analyser); analyser.connect(ctx.destination);
    startViz();
  }
  if(ctx.state==='suspended') ctx.resume();
}

document.getElementById('masterVol').addEventListener('input',e=>{
  if(masterGain) masterGain.gain.setTargetAtTime(parseFloat(e.target.value),ctx.currentTime,.05);
});

// ====== NOISE UTILS ======
function mkBuf(sec,fn){
  const b=ctx.createBuffer(1,ctx.sampleRate*sec,ctx.sampleRate);
  fn(b.getChannelData(0)); return b;
}
function white(sec=2){return mkBuf(sec,d=>{for(let i=0;i<d.length;i++)d[i]=Math.random()*2-1;});}
function pink(sec=3){return mkBuf(sec,d=>{let b0=0,b1=0,b2=0,b3=0,b4=0,b5=0,b6=0;for(let i=0;i<d.length;i++){const w=Math.random()*2-1;b0=.99886*b0+w*.0555179;b1=.99332*b1+w*.0750759;b2=.96900*b2+w*.1538520;b3=.86650*b3+w*.3104856;b4=.55000*b4+w*.5329522;b5=-.7616*b5-w*.0168980;d[i]=(b0+b1+b2+b3+b4+b5+b6+w*.5362)/7;b6=w*.115926;}});}
function brown(sec=3){return mkBuf(sec,d=>{let l=0;for(let i=0;i<d.length;i++){l=(l+.02*(Math.random()*2-1))/1.02;d[i]=l*3.5;}});}

function src(buf){const s=ctx.createBufferSource();s.buffer=buf;s.loop=true;return s;}
function bpf(f,Q=1){const n=ctx.createBiquadFilter();n.type='bandpass';n.frequency.value=f;n.Q.value=Q;return n;}
function lpf(f){const n=ctx.createBiquadFilter();n.type='lowpass';n.frequency.value=f;return n;}
function hpf(f){const n=ctx.createBiquadFilter();n.type='highpass';n.frequency.value=f;return n;}
function lfo(freq,amount,target){const o=ctx.createOscillator();const g=ctx.createGain();o.frequency.value=freq;g.gain.value=amount;o.connect(g);g.connect(target);o.start();return o;}
function fadeIn(g,val=1,t=1.5){g.gain.setValueAtTime(0,ctx.currentTime);g.gain.linearRampToValueAtTime(val,ctx.currentTime+t);return g;}
function chain(...nodes){for(let i=0;i<nodes.length-1;i++)nodes[i].connect(nodes[i+1]);return nodes[nodes.length-1];}

// ====== SOUND GENERATORS ======

// --- NATURE ---
function rainGen(){
  const g=ctx.createGain();
  const s=src(pink(3)); const lp=lpf(8000); const hp=hpf(600);
  chain(s,hp,lp,g); s.start();
  return fadeIn(g,1,1.5);
}
function forestGen(){
  const g=ctx.createGain();
  const s=src(pink(4)); chain(s,lpf(2000),g); s.start();
  function chirp(){
    if(!nodes['forest'])return;
    const o=ctx.createOscillator();const e=ctx.createGain();
    o.type='sine';const f=1800+Math.random()*2500;
    o.frequency.setValueAtTime(f,ctx.currentTime);
    o.frequency.linearRampToValueAtTime(f*1.4,ctx.currentTime+.1);
    e.gain.setValueAtTime(0,ctx.currentTime);e.gain.linearRampToValueAtTime(.05,ctx.currentTime+.02);e.gain.linearRampToValueAtTime(0,ctx.currentTime+.15);
    o.connect(e);e.connect(g);o.start();o.stop(ctx.currentTime+.18);
    setTimeout(chirp,1500+Math.random()*4000);
  }
  setTimeout(chirp,1000);
  return fadeIn(g,1,2);
}
function oceanGen(){
  const g=ctx.createGain();
  const s=src(brown(4)); chain(s,lpf(500),g); s.start();
  lfo(.12,.5,g.gain); g.gain.setValueAtTime(.6,ctx.currentTime);
  return fadeIn(g,.9,3);
}
function streamGen(){
  const g=ctx.createGain();
  const s=src(white(2)); const bp1=bpf(3000,.5); const bp2=bpf(1000,.8);
  s.connect(bp1);bp1.connect(g);s.connect(bp2);bp2.connect(g);s.start();
  lfo(.8,500,bp1.frequency);
  return fadeIn(g,1,1);
}
function windGen(){
  const g=ctx.createGain();
  const s=src(pink(3)); chain(s,lpf(800),g); s.start();
  lfo(.05,.4,g.gain); g.gain.setValueAtTime(.65,ctx.currentTime);
  return fadeIn(g,.85,3);
}
function thunderGen(){
  const g=ctx.createGain();
  const s=src(brown(4)); chain(s,lpf(300),g); s.start();
  function roll(){
    if(!nodes['thunder'])return;
    const n=ctx.createBufferSource();n.buffer=brown(2);
    const e=ctx.createGain();chain(n,lpf(200),e,g);
    e.gain.setValueAtTime(0,ctx.currentTime);e.gain.linearRampToValueAtTime(.4+Math.random()*.3,ctx.currentTime+.1);e.gain.linearRampToValueAtTime(0,ctx.currentTime+1.8);
    n.start();setTimeout(roll,6000+Math.random()*16000);
  }
  setTimeout(roll,2000);
  return fadeIn(g,1,2);
}

// --- WHISPER / EAR CARE ---
function whisperGen(){
  // ウィスパー: フォルマント合成でsssシラブル
  const g=ctx.createGain();
  function syllable(){
    if(!nodes['whisper'])return;
    const w=ctx.createBufferSource();w.buffer=white(.4);w.loop=false;
    const f1=bpf(3500,2);const f2=bpf(7000,1.5);const lp=lpf(9000);
    const e=ctx.createGain();
    w.connect(f1);w.connect(f2);f1.connect(lp);f2.connect(lp);lp.connect(e);e.connect(g);
    const dur=.08+Math.random()*.2;
    e.gain.setValueAtTime(0,ctx.currentTime);
    e.gain.linearRampToValueAtTime(.18,ctx.currentTime+.015);
    e.gain.linearRampToValueAtTime(Math.random()*.1+.08,ctx.currentTime+dur*.6);
    e.gain.linearRampToValueAtTime(0,ctx.currentTime+dur+.05);
    w.start();w.stop(ctx.currentTime+dur+.1);
    const gap=Math.random()<.15 ? .04 : .12+Math.random()*.5;
    setTimeout(syllable,gap*1000);
  }
  setTimeout(syllable,500);
  return fadeIn(g,1,.5);
}

function earpickGen(){
  // 耳かき: カサカサ+コリコリ
  const g=ctx.createGain();
  function pick(){
    if(!nodes['earpick'])return;
    // カサ音
    const w=ctx.createBufferSource();w.buffer=white(.3);
    const hp=hpf(6000);const lp=lpf(15000);const e=ctx.createGain();
    chain(w,hp,lp,e,g);
    const dur=.04+Math.random()*.12;
    e.gain.setValueAtTime(0,ctx.currentTime);e.gain.linearRampToValueAtTime(.22,ctx.currentTime+.01);e.gain.linearRampToValueAtTime(0,ctx.currentTime+dur);
    w.start();w.stop(ctx.currentTime+dur+.02);
    // 時々コリコリ
    if(Math.random()<.35){
      const o=ctx.createOscillator();const oe=ctx.createGain();
