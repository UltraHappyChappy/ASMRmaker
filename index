function spaceGen(){
  const g=ctx.createGain();
  [55,82.4,110,164.8].forEach((f,i)=>{
    const o=ctx.createOscillator();const og=ctx.createGain();
    o.type='sine';o.frequency.value=f;og.gain.value=.15/(i+1);
    lfo(.02+i*.007,f*.005,o.frequency);
    o.connect(og);og.connect(g);o.start();
  });
  return fadeIn(g,1,4);
}
function binauralGen(){
  const g=ctx.createGain();
  const merge=ctx.createChannelMerger(2);
  const lo=ctx.createOscillator();const ro=ctx.createOscillator();
  lo.type=ro.type='sine';lo.frequency.value=200;ro.frequency.value=210;
  const lg=ctx.createGain();const rg=ctx.createGain();
  lg.gain.value=rg.gain.value=.3;
  lo.connect(lg);ro.connect(rg);lg.connect(merge,0,0);rg.connect(merge,0,1);
  merge.connect(g);lo.start();ro.start();
  return fadeIn(g,1,2);
}
function singingGen(){
  const g=ctx.createGain();
  function bowl(){
    if(!nodes['singing'])return;
    const f=432;
    [1,2,3,4,5].map(h=>{
      const o=ctx.createOscillator();const og=ctx.createGain();
      o.type='sine';o.frequency.value=f*h;og.gain.value=.12/h;
      const dur=6+Math.random()*4;
      og.gain.setValueAtTime(0,ctx.currentTime);og.gain.linearRampToValueAtTime(.12/h,ctx.currentTime+.3);og.gain.linearRampToValueAtTime(0,ctx.currentTime+dur);
      o.connect(og);og.connect(g);o.start();o.stop(ctx.currentTime+dur+.1);
    });
    const dur=6+Math.random()*4;
    setTimeout(bowl,(dur+2+Math.random()*3)*1000);
  }
  bowl();
  return fadeIn(g,1,.5);
}
function rainOnWindowGen(){
