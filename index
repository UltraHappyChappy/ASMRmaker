// ====== SCHEDULER / TIMELINE ======
// schedule = [{soundId, startMin, durMin, vol}]
let schedule=[];
let schRunning=false,schStart=0,schAnimFrame=null,schTimeouts=[];
const LANE_W=88; // label width

const allSounds=[...sounds.nature,...sounds.whisper,...sounds.texture,...sounds.ambient];

function buildTimeline(){
  const dur=parseInt(document.getElementById('schDuration').value)||30;
  const ruler=document.getElementById('tlRuler');
  const tracks=document.getElementById('tlTracks');
  const ph=document.getElementById('tlPlayhead');
  ruler.innerHTML='';tracks.innerHTML='';ph.style.display='none';
  const trackW=600; // px for the lane area
  // ruler ticks every 5 min
  const step=5;
  for(let m=0;m<=dur;m+=step){
    const x=LANE_W+(m/dur)*trackW;
    const tick=document.createElement('div');tick.className='tl-ruler-tick';
    tick.style.cssText=`left:${x}px;height:${m%10===0?14:8}px;`;
    if(m%10===0||m===0){const lbl=document.createElement('div');lbl.className='tl-ruler-label';lbl.textContent=m+'分';tick.appendChild(lbl);}
    ruler.appendChild(tick);
  }
  // rows per sound
  allSounds.forEach(s=>{
    const row=document.createElement('div');row.className='tl-row';
    const lbl=document.createElement('div');lbl.className='tl-row-label';lbl.textContent=s.icon+' '+s.name;
    const lane=document.createElement('div');lane.className='tl-lane';lane.style.width=trackW+'px';
    lane.dataset.id=s.id;
    // render existing blocks
    schedule.filter(b=>b.soundId===s.id).forEach(b=>addBlockEl(lane,b,dur,trackW));
    // click to add block
    lane.addEventListener('click',e=>{
      if(e.target.classList.contains('tl-block')||e.target.classList.contains('tl-block-x'))return;
      const rect=lane.getBoundingClientRect();
      const xRatio=(e.clientX-rect.left)/trackW;
      const startMin=Math.max(0,Math.min(dur-1,Math.round(xRatio*dur*4)/4));
      const block={soundId:s.id,startMin,durMin:Math.min(5,dur-startMin),vol:.7};
      schedule.push(block);addBlockEl(lane,block,dur,trackW);
    });
    row.appendChild(lbl);row.appendChild(lane);tracks.appendChild(row);
  });
  document.getElementById('timeline').style.width=(LANE_W+trackW+20)+'px';
}

function addBlockEl(lane,block,dur,trackW){
  const el=document.createElement('div');el.className='tl-block';
  const x=(block.startMin/dur)*trackW;
  const w=Math.max(20,(block.durMin/dur)*trackW);
  el.style.cssText=`left:${x}px;width:${w}px;`;
  const lbl=document.createElement('div');lbl.className='tl-block-x';lbl.textContent=block.startMin+'分 '+block.durMin+'m';
  el.appendChild(lbl);
  // click to remove
  el.addEventListener('click',e=>{e.stopPropagation();schedule=schedule.filter(b=>b!==block);el.remove();});
  // drag to move
  let dragging=false,dragStartX=0,origStart=0;
  el.addEventListener('pointerdown',e=>{
    if(e.target===el||e.target===lbl){dragging=true;dragStartX=e.clientX;origStart=block.startMin;e.preventDefault();}
  });
  window.addEventListener('pointermove',e=>{
    if(!dragging)return;
    const dx=e.clientX-dragStartX;const dm=(dx/trackW)*dur;
    block.startMin=Math.max(0,Math.min(dur-block.durMin,origStart+dm));
    el.style.left=((block.startMin/dur)*trackW)+'px';
    lbl.textContent=Math.round(block.startMin*10)/10+'分 '+block.durMin+'m';
  });
  window.addEventListener('pointerup',()=>{dragging=false;});
  // right-edge resize
  const resizer=document.createElement('div');
  resizer.style.cssText='position:absolute;right:0;top:0;bottom:0;width:8px;cursor:ew-resize;';
  let resizing=false,resizeStartX=0,origDur=0;
  resizer.addEventListener('pointerdown',e=>{resizing=true;resizeStartX=e.clientX;origDur=block.durMin;e.stopPropagation();e.preventDefault();});
  window.addEventListener('pointermove',e=>{
    if(!resizing)return;
    const dx=e.clientX-resizeStartX;const dm=(dx/trackW)*dur;
    block.durMin=Math.max(.25,Math.min(dur-block.startMin,origDur+dm));
    el.style.width=Math.max(20,(block.durMin/dur)*trackW)+'px';
    lbl.textContent=Math.round(block.startMin*10)/10+'分 '+Math.round(block.durMin*10)/10+'m';
  });
  window.addEventListener('pointerup',()=>{resizing=false;});
  el.appendChild(resizer);
  lane.appendChild(el);
}

function schPlay(){
  if(schRunning)return;ensureCtx();
  const dur=parseInt(document.getElementById('schDuration').value)||30;
  schRunning=true;schStart=Date.now();
  const ph=document.getElementById('tlPlayhead');
  const trackW=600;
  ph.style.display='block';
  // schedule timeouts
  const all=[...sounds.nature,...sounds.whisper,...sounds.texture,...sounds.ambient];
  schedule.forEach(b=>{
    const startMs=b.startMin*60000;const stopMs=(b.startMin+b.durMin)*60000;
    const t1=setTimeout(()=>{
      if(!schRunning)return;
      const s=all.find(x=>x.id===b.soundId);if(!s)return;
      if(!nodes[b.soundId]){const g=s.gen();g.gain.value=b.vol;g.connect(masterGain);nodes[b.soundId]=g;document.getElementById('card-'+b.soundId)?.classList.add('playing');updateCount();}
    },startMs);
    const t2=setTimeout(()=>{
      if(!schRunning)return;
      if(nodes[b.soundId]){nodes[b.soundId].gain.linearRampToValueAtTime(0,ctx.currentTime+1);setTimeout(()=>{if(nodes[b.soundId]){nodes[b.soundId].disconnect();delete nodes[b.soundId];}},1100);document.getElementById('card-'+b.soundId)?.classList.remove('playing');updateCount();}
    },stopMs);
    schTimeouts.push(t1,t2);
  });
  // total stop
  const tEnd=setTimeout(()=>schStop(),dur*60000);schTimeouts.push(tEnd);
  // playhead animation
  (function anim(){
    if(!schRunning)return;
    const elapsed=(Date.now()-schStart)/1000/60;
    const x=LANE_W+(elapsed/dur)*trackW;
    ph.style.left=x+'px';
    const em=Math.floor(elapsed*60);const m=Math.floor(em/60);const s=em%60;
    document.getElementById('schDisplay').textContent=String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
    schAnimFrame=requestAnimationFrame(anim);
  })();
  document.getElementById('schPlayBtn').textContent='▶ 再生中';
}

function schStop(){
  schRunning=false;schTimeouts.forEach(clearTimeout);schTimeouts=[];
  if(schAnimFrame)cancelAnimationFrame(schAnimFrame);
  document.getElementById('tlPlayhead').style.display='none';
  document.getElementById('schDisplay').textContent='00:00';
  document.getElementById('schPlayBtn').textContent='▶ 再生';
  stopAll();
}

function schClear(){
  schStop();schedule=[];buildTimeline();
}

function schSave(){
  localStorage.setItem('asmr_schedule',JSON.stringify({schedule,dur:document.getElementById('schDuration').value}));
  alert('スケジュールを保存しました');
}

function schLoad(){
  const d=localStorage.getItem('asmr_schedule');if(!d)return alert('保存済みスケジュールがありません');
  const o=JSON.parse(d);schedule=o.schedule||[];
  document.getElementById('schDuration').value=o.dur||30;
  buildTimeline();
}
</script>
