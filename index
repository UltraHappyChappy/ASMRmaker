function stopAll(){
  Object.keys(nodes).forEach(id=>{
    if(nodes[id]){nodes[id].gain.linearRampToValueAtTime(0,ctx?ctx.currentTime+.8:0);setTimeout(()=>{if(nodes[id]){nodes[id].disconnect();delete nodes[id];}},900);}
    document.getElementById('card-'+id)?.classList.remove('playing');
