function tapGen(){
  // 頭皮タッピング: 指が頭を優しくトン
  const g=ctx.createGain();
  function tap(){
    if(!nodes['tap'])return;
    const count=Math.random()<.5 ? 1 : 2+Math.floor(Math.random()*3);
    for(let i=0;i<count;i++){
      setTimeout(()=>{
        if(!nodes['tap'])return;
        const o=ctx.createOscillator();const e=ctx.createGain();const lp2=lpf(400);
        o.type='sine';o.frequency.value=100+Math.random()*60;
        e.gain.setValueAtTime(.15,ctx.currentTime);e.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.18);
        // 皮膚摩擦ノイズ
        const w=ctx.createBufferSource();w.buffer=white(.1);
        const wg=ctx.createGain();wg.gain.value=.04;
        w.connect(wg);wg.connect(g);w.start();
        chain(o,lp2,e,g);o.start();o.stop(ctx.currentTime+.2);
      },i*80);
    }
    setTimeout(tap,600+Math.random()*2000);
  }
  setTimeout(tap,200);
  return fadeIn(g,1,.5);
}

