function cafeGen(){
  const g=ctx.createGain();
  const s=src(pink(4));chain(s,bpf(1500,.3),g);s.start();
  function clink(){
    if(!nodes['cafe'])return;
    const o=ctx.createOscillator();const e=ctx.createGain();
