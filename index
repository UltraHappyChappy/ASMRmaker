    const o=ctx.createOscillator();const e=ctx.createGain();
    o.type='sine';o.frequency.value=800+Math.random()*400;
    e.gain.setValueAtTime(.03,ctx.currentTime);e.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+.25);
    o.connect(e);e.connect(g);o.start();o.stop(ctx.currentTime+.3);
    setTimeout(drop,50+Math.random()*300);
  }
  setTimeout(drop,500);
  return fadeIn(g,1,2);
}


function brushingGen(){
  const g=ctx.createGain(); g.gain.value=0;
  function startPlayback(){
    const s=ctx.createBufferSource();
    s.buffer=brushingBuffer; s.loop=true;
    s.connect(g); s.start();
    g.gain.linearRampToValueAtTime(1,ctx.currentTime+1.5);
  }
  if(brushingBuffer){
    startPlayback();
  } else {
    // デコード完了を待ってから再生
    const bin=atob(BRUSHING_B64);
    const bytes=new Uint8Array(bin.length);
    for(let i=0;i<bin.length;i++) bytes[i]=bin.charCodeAt(i);
    ctx.decodeAudioData(bytes.buffer.slice(0)).then(buf=>{
      brushingBuffer=buf;
      if(nodes['brushing']) startPlayback();
    }).catch(e=>console.error('brushing decode error:',e));
  }
  return g;
}

